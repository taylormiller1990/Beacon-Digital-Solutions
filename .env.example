# Beacon licensing backend — environment variables
# Copy this file to ".env" for LOCAL testing (never commit the real .env),
# or paste these as Environment Variables in your host (Render/Railway/Fly).
#
# ----- Stripe (use TEST values first, then swap to LIVE when ready) -----
# Secret API key:  Stripe Dashboard → Developers → API keys
STRIPE_SECRET_KEY=sk_test_xxx
# Price ID of your $8/mo recurring product:  Stripe → Products → your price
PREMIUM_PRICE_ID=price_xxx
# Webhook signing secret:  Stripe → Developers → Webhooks → your endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxx

# ----- Email delivery (REQUIRED so customers receive their license key) -----
# Free key at https://resend.com  (verify your sending domain there)
RESEND_API_KEY=re_xxx

# ----- App / security -----
# Long random string used to sign licenses. Generate one, e.g.:
#   python3 -c "import secrets; print(secrets.token_hex(32))"
LICENSE_SIGNING_SECRET=change-me-to-a-long-random-string
# Public URL of THIS backend (used for Stripe success/cancel redirects)
BACKEND_BASE_URL=https://api.beacondigitalsolutionsllc.com
# Password for the /admin pages (contacts + feedback)
ADMIN_PASSWORD=choose-a-strong-password

# ----- Persistence -----
# Path to the SQLite DB on the host's PERSISTENT disk so license keys survive
# restarts. On Render with a disk mounted at /var/data, use:
DB_PATH=/var/data/licenses.db

# ----- Local-only convenience -----
# Set to 1 ONLY for local debugging. Leave unset in production.
# FLASK_DEBUG=1
# PORT=5001
